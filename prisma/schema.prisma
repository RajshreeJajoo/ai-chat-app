datasource db {
  provider = "mongodb"
}

generator client {
  provider = "prisma-client-js"
}

model Chat {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  role      String   // "user" or "model"
  content   String
  chat      Chat     @relation(fields: [chatId], references: [id])
  chatId    String   @db.ObjectId
  createdAt DateTime @default(now())
}